# ─────────────────────────────────────────────────────────────
# Zyrix Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zyrix

# JWT
JWT_SECRET=your-secret-key-change-in-production-min-64-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5

# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://zyrix.co

# SMS (for production - skip for now)
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Admin JWT
ADMIN_JWT_SECRET=your_admin_jwt_secret_minimum_32_characters
ADMIN_JWT_EXPIRES_IN=8h

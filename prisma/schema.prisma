// ─────────────────────────────────────────────────────────────
// Zyrix CRM — Quotes & Proposals Schema Addition
// أضف هذه الـ enums والـ models لملف schema.prisma الحالي
// ─────────────────────────────────────────────────────────────

// ── أضف هذه الـ Enums ──────────────────────────────────────

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum QuoteLanguage {
  AR
  TR
  EN
}

// ── أضف هذه الـ Models ─────────────────────────────────────

model QuoteTemplate {
  id         String        @id @default(uuid())
  merchantId String
  name       String
  language   QuoteLanguage @default(AR)
  headerNote String?
  footerNote String?
  terms      String?
  isDefault  Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  merchant   Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  quotes     Quote[]

  @@index([merchantId])
  @@map("quote_templates")
}

model Quote {
  id           String        @id @default(uuid())
  merchantId   String
  quoteId      String        @unique  // e.g. QT-2024-0001
  customerId   String?
  templateId   String?
  language     QuoteLanguage @default(AR)
  status       QuoteStatus   @default(DRAFT)

  // بيانات العميل (مخزنة مباشرة للمرونة — لا يشترط وجود customer record)
  customerName    String
  customerEmail   String?
  customerPhone   String?
  customerCompany String?
  customerAddress String?

  // بيانات العرض
  title       String
  description String?
  currency    String        @default("SAR")
  items       Json          // QuoteLineItem[]
  subtotal    Decimal       @db.Decimal(18, 2)
  discountType   String?    // "percent" | "fixed"
  discountValue  Decimal?   @db.Decimal(18, 2)
  discountAmount Decimal?   @db.Decimal(18, 2)
  taxRate        Decimal?   @db.Decimal(5, 2)   // نسبة الضريبة %
  taxAmount      Decimal?   @db.Decimal(18, 2)
  total          Decimal    @db.Decimal(18, 2)

  // شروط وملاحظات
  headerNote  String?
  footerNote  String?
  terms       String?

  // تواريخ
  issueDate   DateTime      @default(now())
  expiryDate  DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?

  // رابط العرض العام (token-based)
  viewToken   String        @unique @default(uuid())
  viewCount   Int           @default(0)

  // تحويل لفاتورة
  convertedToInvoiceId String?

  // ربط بـ Sales Pipeline deal (مستقبلي)
  dealId      String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  merchant    Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer    Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  template    QuoteTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  activities  QuoteActivity[]

  @@index([merchantId])
  @@index([merchantId, status])
  @@index([merchantId, createdAt])
  @@index([viewToken])
  @@map("quotes")
}

// سجل أنشطة العرض (أُرسل، فُتح، قُبل، ...)
model QuoteActivity {
  id        String   @id @default(uuid())
  quoteId   String
  type      String   // "created" | "sent" | "viewed" | "accepted" | "rejected" | "expired" | "converted"
  note      String?
  metadata  Json?
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_activities")
}


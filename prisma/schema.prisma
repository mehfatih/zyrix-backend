// ─────────────────────────────────────────────────────────────
// Zyrix Payment Gateway — Prisma Schema (with Admin)
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  AR
  TR
  EN
}

enum Currency {
  SAR
  TRY
  USD
  EUR
  AED
  KWD
  QAR
  IQD
}

enum MerchantStatus {
  ACTIVE
  SUSPENDED
  PENDING_KYC
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionStatus {
  SUCCESS
  PENDING
  FAILED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  DIGITAL_WALLET
  CRYPTO
}

enum SettlementStatus {
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

enum RefundStatus {
  PROCESSING
  COMPLETED
  REJECTED
}

enum TransferStatus {
  PENDING
  COMPLETED
  FAILED
}

enum CODStatus {
  PENDING
  OUT_FOR_DELIVERY
  COLLECTED
  FAILED
  RETURNED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubInterval {
  MONTHLY
  YEARLY
}

enum SubStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum LinkStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum NotificationType {
  PAYMENT
  SETTLEMENT
  DISPUTE
  SYSTEM
  SECURITY
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT
  FINANCE
}

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(SUPPORT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@map("admins")
}

model Merchant {
  id                String         @id @default(uuid())
  name              String
  email             String         @unique
  phone             String         @unique
  passwordHash      String?
  merchantId        String         @unique
  language          Language       @default(EN)
  currency          Currency       @default(SAR)
  status            MerchantStatus @default(ACTIVE)
  kycStatus         KycStatus      @default(PENDING)
  businessName      String?
  businessType      String?
  country           String
  timezone          String         @default("UTC")
  onboardingDone    Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  transactions      Transaction[]
  settlements       Settlement[]
  disputes          Dispute[]
  refunds           Refund[]
  invoices          Invoice[]
  expenses          Expense[]
  revenueGoals      RevenueGoal[]
  subscriptions     Subscription[]
  paymentLinks      PaymentLink[]
  notifications     Notification[]
  apiKeys           ApiKey[]
  webhooks          Webhook[]
  codOrders         CODOrder[]
  sentTransfers     Transfer[]     @relation("SentTransfers")
  receivedTransfers Transfer[]     @relation("ReceivedTransfers")
  @@map("merchants")
}

model Transaction {
  id            String            @id @default(uuid())
  merchantId    String
  transactionId String            @unique
  amount        Decimal           @db.Decimal(18, 2)
  currency      String
  status        TransactionStatus
  method        PaymentMethod
  customerName  String
  customerEmail String?
  customerPhone String?
  country       String
  flag          String
  isCredit      Boolean
  description   String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  merchant      Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  disputes      Dispute[]
  refunds       Refund[]
  @@map("transactions")
}

model Settlement {
  id            String           @id @default(uuid())
  merchantId    String
  settlementId  String           @unique
  amount        Decimal          @db.Decimal(18, 2)
  commission    Decimal          @db.Decimal(18, 2)
  netAmount     Decimal          @db.Decimal(18, 2)
  currency      String
  status        SettlementStatus
  bankName      String
  bankAccount   String
  scheduledDate DateTime
  completedDate DateTime?
  createdAt     DateTime         @default(now())
  merchant      Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("settlements")
}

model Dispute {
  id            String        @id @default(uuid())
  merchantId    String
  transactionId String
  disputeId     String        @unique
  reason        String
  amount        Decimal       @db.Decimal(18, 2)
  currency      String
  status        DisputeStatus
  resolution    String?
  evidence      Json?
  createdAt     DateTime      @default(now())
  resolvedAt    DateTime?
  merchant      Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  transaction   Transaction   @relation(fields: [transactionId], references: [id])
  @@map("disputes")
}

model Refund {
  id            String       @id @default(uuid())
  merchantId    String
  transactionId String
  refundId      String       @unique
  amount        Decimal      @db.Decimal(18, 2)
  currency      String
  reason        String
  status        RefundStatus @default(PROCESSING)
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  merchant      Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  transaction   Transaction  @relation(fields: [transactionId], references: [id])
  @@map("refunds")
}

model Transfer {
  id             String         @id @default(uuid())
  transferId     String         @unique
  fromMerchantId String
  toMerchantId   String
  amount         Decimal        @db.Decimal(18, 2)
  currency       String
  description    String?
  status         TransferStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  fromMerchant   Merchant       @relation("SentTransfers", fields: [fromMerchantId], references: [id], onDelete: Cascade)
  toMerchant     Merchant       @relation("ReceivedTransfers", fields: [toMerchantId], references: [id], onDelete: Cascade)
  @@map("transfers")
}

model CODOrder {
  id               String    @id @default(uuid())
  merchantId       String
  orderId          String    @unique
  customerName     String
  amount           Decimal   @db.Decimal(18, 2)
  currency         String    @default("SAR")
  address          String
  phone            String?
  description      String?
  status           CODStatus @default(PENDING)
  collectedAmount  Decimal   @default(0) @db.Decimal(18, 2)
  collectedAt      DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  merchant         Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("cod_orders")
}

model Invoice {
  id           String        @id @default(uuid())
  merchantId   String
  invoiceId    String        @unique
  customerName String
  total        Decimal       @db.Decimal(18, 2)
  currency     String
  status       InvoiceStatus
  items        Json
  dueDate      DateTime
  paidDate     DateTime?
  createdAt    DateTime      @default(now())
  merchant     Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("invoices")
}

model Expense {
  id          String   @id @default(uuid())
  merchantId  String
  category    String
  description String
  amount      Decimal  @db.Decimal(18, 2)
  currency    String
  date        DateTime
  createdAt   DateTime @default(now())
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("expenses")
}

model RevenueGoal {
  id            String     @id @default(uuid())
  merchantId    String
  name          String
  targetAmount  Decimal    @db.Decimal(18, 2)
  currentAmount Decimal    @default(0) @db.Decimal(18, 2)
  currency      String
  period        GoalPeriod
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime   @default(now())
  merchant      Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("revenue_goals")
}

model Subscription {
  id                 String      @id @default(uuid())
  merchantId         String
  planName           String
  amount             Decimal     @db.Decimal(18, 2)
  currency           String
  interval           SubInterval
  status             SubStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime    @default(now())
  merchant           Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("subscriptions")
}

model PaymentLink {
  id          String        @id @default(uuid())
  merchantId  String
  linkId      String        @unique
  title       String
  description String?
  amount      Decimal?      @db.Decimal(18, 2)
  minAmount   Decimal?      @db.Decimal(18, 2)
  maxAmount   Decimal?      @db.Decimal(18, 2)
  currency    String
  url         String
  status      LinkStatus
  expiresAt   DateTime?
  usageCount  Int           @default(0)
  paidCount   Int           @default(0)
  features    String?
  faqs        String?
  allowNote   Boolean       @default(false)
  showQr      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  merchant    Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payments    LinkPayment[]
  @@map("payment_links")
}

model LinkPayment {
  id          String      @id @default(uuid())
  linkId      String
  paymentLink PaymentLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  txId        String      @unique
  amount      Decimal     @db.Decimal(18, 2)
  currency    String
  payerName   String
  payerPhone  String
  payerNote   String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  status      String      @default("COMPLETED")
  createdAt   DateTime    @default(now())
  @@map("link_payments")
}

model Notification {
  id         String           @id @default(uuid())
  merchantId String
  title      String
  body       String
  type       NotificationType
  isRead     Boolean          @default(false)
  data       Json?
  createdAt  DateTime         @default(now())
  merchant   Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("notifications")
}

model ApiKey {
  id         String    @id @default(uuid())
  merchantId String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("api_keys")
}

model Webhook {
  id              String    @id @default(uuid())
  merchantId      String
  name            String
  url             String
  events          String[]
  secret          String
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  merchant        Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  @@map("webhooks")
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  @@map("otp_codes")
}
